# ═══════════════════════════════════════════════════════════════════════════════
# ds-vault — Web3 / IPFS Configuration Template
# ═══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env.web3 and fill in your values.
# .env.web3 is git-ignored — NEVER commit real private keys.
#
# Quick start (testnet only):
#   1. cp .env.web3.example .env.web3
#   2. Set USE_BLOCKCHAIN=true
#   3. Fill VAULT_WALLET_ADDRESS and VAULT_PRIVATE_KEY
#   4. Deploy: cd contracts && npm install && npm run deploy:amoy
#   5. Copy printed address into POLYGON_AMOY_CONTRACT_ADDRESS below
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Feature Flags ─────────────────────────────────────────────────────────────
# Set to true to enable. Vault works identically to original when both are false.
USE_BLOCKCHAIN=false
USE_IPFS=false

# ─── Active Chain ──────────────────────────────────────────────────────────────
# Options: polygon_amoy (default), polygon_mainnet, ethereum_sepolia,
#          arbitrum_sepolia, base_sepolia, optimism_sepolia
ACTIVE_CHAIN=polygon_amoy

# ─── Wallet (REQUIRED for blockchain writes) ──────────────────────────────────
# NEVER commit real values. Use a dedicated vault wallet, not your main wallet.
VAULT_WALLET_ADDRESS=0xYourWalletAddressHere
VAULT_PRIVATE_KEY=0xYourPrivateKeyHere

# ─── Gas Limit ─────────────────────────────────────────────────────────────────
# Conservative default. Reduce if you want cheaper gas; increase if txns revert.
VAULT_GAS_LIMIT=200000

# ═══════════════════════════════════════════════════════════════════════════════
# CONTRACT ADDRESSES (fill in after deploying with: npm run deploy:<chain>)
# ═══════════════════════════════════════════════════════════════════════════════
POLYGON_AMOY_CONTRACT_ADDRESS=
POLYGON_CONTRACT_ADDRESS=
SEPOLIA_CONTRACT_ADDRESS=
ARBITRUM_SEPOLIA_CONTRACT_ADDRESS=
BASE_SEPOLIA_CONTRACT_ADDRESS=
OPTIMISM_SEPOLIA_CONTRACT_ADDRESS=

# ═══════════════════════════════════════════════════════════════════════════════
# RPC ENDPOINTS (public fallbacks are pre-configured; override for better rates)
# Get a free key from Alchemy (alchemy.com) or Infura (infura.io)
# ═══════════════════════════════════════════════════════════════════════════════

# Polygon Amoy (testnet)
POLYGON_AMOY_RPC=https://rpc-amoy.polygon.technology
POLYGON_AMOY_RPC_FALLBACK=https://polygon-amoy.drpc.org

# Polygon Mainnet
POLYGON_RPC=https://polygon-rpc.com
POLYGON_RPC_FALLBACK=https://polygon.drpc.org

# Ethereum Sepolia (testnet)
SEPOLIA_RPC=https://rpc.sepolia.org
SEPOLIA_RPC_FALLBACK=https://ethereum-sepolia.drpc.org

# Arbitrum Sepolia (testnet)
ARBITRUM_SEPOLIA_RPC=https://sepolia-rollup.arbitrum.io/rpc
ARBITRUM_SEPOLIA_RPC_FALLBACK=https://arbitrum-sepolia.drpc.org

# Base Sepolia (testnet)
BASE_SEPOLIA_RPC=https://sepolia.base.org
BASE_SEPOLIA_RPC_FALLBACK=https://base-sepolia.drpc.org

# Optimism Sepolia (testnet)
OPTIMISM_SEPOLIA_RPC=https://sepolia.optimism.io
OPTIMISM_SEPOLIA_RPC_FALLBACK=https://optimism-sepolia.drpc.org

# ═══════════════════════════════════════════════════════════════════════════════
# IPFS / PINATA (required only when USE_IPFS=true)
# Get a free JWT at: https://app.pinata.cloud/keys
# ═══════════════════════════════════════════════════════════════════════════════
PINATA_JWT=
PINATA_GATEWAY=https://gateway.pinata.cloud
IPFS_PUBLIC_GATEWAY=https://ipfs.io
IPFS_REQUEST_TIMEOUT=30

# ═══════════════════════════════════════════════════════════════════════════════
# BLOCK EXPLORER API KEYS (optional — only needed for contract verification)
# ═══════════════════════════════════════════════════════════════════════════════
POLYGONSCAN_API_KEY=
ETHERSCAN_API_KEY=
ARBISCAN_API_KEY=
BASESCAN_API_KEY=
OPTIMISM_API_KEY=

# ─── Performance (optional) ────────────────────────────────────────────────────
# Set REPORT_GAS=true to see gas usage during Hardhat tests
REPORT_GAS=false
COINMARKETCAP_API_KEY=
