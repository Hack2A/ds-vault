# ─── Render Environment Variables Reference ───────────────────────────────────
# Copy these into your Render dashboard → Environment.
# DO NOT commit real values to git.
# ─────────────────────────────────────────────────────────────────────────────

# Django core
SECRET_KEY=<generate-a-long-random-string>
DEBUG=False
ALLOWED_HOSTS=ds-vault-backend.onrender.com

# PostgreSQL (auto-set by Render when DATABASE_URL is linked to a database)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# CORS — add your frontend URL (Render, Vercel, etc.)
CORS_ALLOWED_ORIGINS=https://your-frontend-url.onrender.com,https://your-vercel-app.vercel.app

# Gmail SMTP (use an App Password, NOT your real Gmail password)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password
